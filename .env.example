APP_NAME=PrintWorks
APP_ENV=local
APP_KEY=
APP_DEBUG=true
# Used for absolute image URLs in the storefront API (asset()). Must be reachable from the browser.
APP_URL=http://localhost:8000
# Uploads: php artisan storage:link  →  public/storage → storage/app/public

LOG_CHANNEL=stack
LOG_LEVEL=debug

# MySQL
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=printworks_db
DB_USERNAME=root
DB_PASSWORD=

# Redis (cache, sessions, queues)
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

CACHE_STORE=redis
SESSION_DRIVER=redis
QUEUE_CONNECTION=redis

# Laravel Sanctum (API auth)
SANCTUM_STATEFUL_DOMAINS=localhost,127.0.0.1

# S3 / Cloudflare R2
FILESYSTEM_DISK=s3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=auto
AWS_BUCKET=
AWS_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
AWS_USE_PATH_STYLE_ENDPOINT=false

# Optional: for AWS S3 use
# AWS_ENDPOINT=
